# ─────────────────────────────────────────────────────────────────────────────
# ETS ERPNext — PROD environment template
#
# Copy this file to `.env` next to compose.yml, then fill in real values.
# `.env` is gitignored (see ../../.gitignore) — never commit secrets.
#
# Generate secrets with:
#   openssl rand -hex 24    # 48 hex chars, suitable for DB password
#   openssl rand -hex 32    # 64 hex chars, suitable for admin password
# ─────────────────────────────────────────────────────────────────────────────

# ── Stack identity ──────────────────────────────────────────────────────────
# Used as a prefix for container names, volumes, and network name.
# Lowercase, no spaces. Different value per environment if you run dev+prod on
# the same host (e.g., ets_prod on the college server, ets_prod_dryrun on Mac).
STACK_NAME=ets_prod

# ── Container image ─────────────────────────────────────────────────────────
# Pin to the same release tag dev uses, so DB backups are restorable.
# Bump in lockstep with a coordinated dev→prod cutover.
FRAPPE_IMAGE=frappe/erpnext:v16.15.1

# ── Custom apps source on the host ──────────────────────────────────────────
# Absolute path to the parent directory that contains `ets_admissions/` and
# `ets_students/` as git clones. Example layouts:
#   Mac dry-run:      REPOS_ROOT=/Users/injeti/ets-repos
#   Linux server:     REPOS_ROOT=/opt/aca/repos
REPOS_ROOT=/opt/aca/repos

# ── Site identity ───────────────────────────────────────────────────────────
# Frappe site name (must match the Host header browsers send).
# For LAN-only, use something like erp.aca.local (and add an /etc/hosts entry
# on each staff workstation, OR set up an internal DNS A record).
SITE_NAME=erp.aca.local

# ── Database secrets ────────────────────────────────────────────────────────
# Used by MariaDB on first init AND by every Frappe service to connect.
# Once set, do NOT change these without also rotating in MariaDB.
DB_ROOT_PASSWORD=replace_with_openssl_rand_hex_24

# ── Site admin credentials ──────────────────────────────────────────────────
# Set on first boot only (when create-site runs). After that, change via Desk.
ADMIN_PASSWORD=replace_with_openssl_rand_hex_32

# ── Networking ──────────────────────────────────────────────────────────────
# Host port to expose the frontend on. Defaults to 8080; pick 8081 if running
# the prod compose alongside the dev pwd.yml stack on the same machine.
WEB_PORT=8080

# Bind address for the host port. Defaults to 0.0.0.0 (all interfaces, fine on
# a LAN-only college server). Use 127.0.0.1 if a reverse proxy will sit in
# front of this compose stack on the same host.
BIND_ADDR=0.0.0.0
