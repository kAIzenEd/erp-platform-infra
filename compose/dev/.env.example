# ETS ERPNext — DEV environment template
# Copy to .env next to compose.yml. Never commit .env.

STACK_NAME=ets_dev
FRAPPE_IMAGE=frappe/erpnext:v16.15.1
REPOS_ROOT=/opt/aca/repos

# Must match Mac frappe_docker pwd.yml site name and backup filenames (*-frontend-*)
SITE_NAME=frontend

DB_ROOT_PASSWORD=replace_with_openssl_rand_hex_24
ADMIN_PASSWORD=replace_with_openssl_rand_hex_32

WEB_PORT=8081
BIND_ADDR=0.0.0.0
